# Porta que o servidor irá rodar
PORT=3000

# URI de conexão com o MongoDB
# Ex: mongodb://usuario:senha@localhost:27017/nome_do_banco
MONGO_URI=

# Chave secreta para JWT (tokens de autenticação)
# Gere uma string longa e aleatória, ex: openssl rand -base64 32
JWT_SECRET=

# Chave da API de reenvio de emails (ex: SendGrid, Resend)
RESEND_API_KEY=